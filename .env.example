# ── HorizonView Gen 2 — Environment Configuration ─────────────────────────────
# Copy to .env.local for local dev; set the same vars in Vercel Project Settings.
# With NO variables set, the app runs in DEMO MODE with realistic mock data.

# ── Mode ──────────────────────────────────────────────────────────────────────
# "demo" (default) = mock data, no login required
# "live"           = Entra ID login + real Microsoft data sources
HV_MODE=demo

# ── Auth.js / Microsoft Entra ID (required in live mode) ─────────────────────
# Entra admin center → App registrations → New registration
#   Redirect URI (web): https://<your-domain>/api/auth/callback/microsoft-entra-id
# Generate AUTH_SECRET with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# ── Power BI / Fabric (live mode) ─────────────────────────────────────────────
# Service principal with workspace access. Used for executeQueries (DAX) against
# the HorizonView Semantic Model and for Fabric REST APIs.
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_DATASET_ID=
# Fabric notebook that produces AI insights (triggered by the weekly cron)
FABRIC_INSIGHTS_NOTEBOOK_ID=
# Optional deep links shown on the Dashboards page (comma-separated name|url pairs)
POWERBI_REPORT_LINKS=Portfolio Overview|https://app.powerbi.com/...,Executive Health|https://app.powerbi.com/...

# ── Project Elevate details not stored in the semantic model (optional) ──────
HV_PROJECT_CODE=ELEVATE
HV_PROJECT_PORTFOLIO=Aberdeen Advisors
HV_PROJECT_SPONSOR=
HV_PROJECT_PM=
HV_PROJECT_PHASE=Delivery
HV_PROJECT_BUDGET=0
HV_PROJECT_ACTUALS=0
HV_PROJECT_FAC=0
HV_PROJECT_SHAREPOINT_URL=
HV_PROJECT_REPORT_URL=

# ── Microsoft Graph / SharePoint (live mode) ─────────────────────────────────
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
SHAREPOINT_SITE_ID=

# ── Document intelligence (auto-selected, lowest friction first) ─────────────
# Default: Graph Search API — free, every M365 tenant, uses GRAPH_* creds above.
# App-only search requires Sites.Read.All (application) + a region:
GRAPH_SEARCH_REGION=NAM
# Upgrade: Copilot Retrieval API (requires M365 Copilot licensing in the tenant)
COPILOT_RETRIEVAL=false

# ── AI (live mode) ────────────────────────────────────────────────────────────
# Either Azure OpenAI...
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# ...or the OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── ElevenLabs (Executive tier: renders podcast updates to MP3 in-app) ───────
ELEVENLABS_API_KEY=
# Optional voice overrides (defaults: Mark & Ellen)
ELEVENLABS_VOICE_MARK=
ELEVENLABS_VOICE_ELLEN=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Onyx (OPTIONAL self-hosted document backend; not required) ───────────────
ONYX_BASE_URL=
ONYX_API_KEY=

# ── HorizonView tier ──────────────────────────────────────────────────────────
# core         = portal, dashboards, SharePoint links
# intelligence = + AI insights, Ask Horizon, one-click PPTX
# executive    = + podcast updates (Podcastfy in Fabric), scheduled AI reports
# Demo mode shows all tiers. Default in live mode: intelligence
HV_TIER=executive
# Fabric notebook that renders podcast updates (Podcastfy) — exec